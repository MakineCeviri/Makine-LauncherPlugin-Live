{
    "id": "com.makineceviri.live",
    "name": "MakineAI Live",
    "version": "0.2.0",
    "apiVersion": 1,
    "category": "translation",
    "description": "Real-time screen OCR and translation overlay",
    "author": "MakineAI Team",
    "license": "GPL-3.0",
    "homepage": "https://github.com/MakineCeviri/MakineAI-Plugin-OCR",
    "entry": "makineai-live.dll",
    "dependencies": [],
    "capabilities": ["network", "screen_capture"],
    "features": [
        "Screen capture (GDI/DXGI)",
        "OCR (RapidOCR/PaddleOCR)",
        "Translation (GPT, DeepL)",
        "Configurable language pair"
    ],
    "platforms": ["win64"],
    "minLauncherVersion": "0.2.0",
    "settings": [
        {
            "key": "sourceLang",
            "type": "select",
            "label": "Kaynak Dil",
            "options": ["en", "ja", "ko", "zh", "de", "fr", "es", "ru"],
            "default": "en"
        },
        {
            "key": "targetLang",
            "type": "select",
            "label": "Hedef Dil",
            "options": ["tr", "en", "de", "fr", "es"],
            "default": "tr"
        },
        {
            "key": "translatorEngine",
            "type": "select",
            "label": "Çeviri Motoru",
            "options": ["gpt", "deepl"],
            "default": "gpt"
        },
        {
            "key": "apiKey",
            "type": "password",
            "label": "API Anahtarı",
            "default": ""
        },
        {
            "key": "gptModel",
            "type": "select",
            "label": "GPT Modeli",
            "options": ["gpt-4o-mini", "gpt-4o", "gpt-4.1-mini", "gpt-4.1-nano"],
            "default": "gpt-4o-mini"
        }
    ]
}
